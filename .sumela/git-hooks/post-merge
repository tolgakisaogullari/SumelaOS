#!/usr/bin/env bash
# post-merge — fires after `git merge` and after the merge step of `git pull`.
# Re-ingests session summaries that arrived in this merge into the local Qdrant.
#
# NOTE: `git pull --rebase` does NOT trigger post-merge. Rebase-pull users get
# coverage from post-checkout (HEAD moves) or can re-ingest manually; the
# session bootstrap also surfaces summaries not yet in local memory.

. "$(dirname "$0")/_lib.sh"

# ORIG_HEAD = the pre-merge HEAD that git records before a merge.
from="$(git rev-parse --verify --quiet ORIG_HEAD 2>/dev/null)"
[ -n "$from" ] || from="HEAD^"

# Migrate LOCAL Qdrant collections to per-project namespacing BEFORE the Qdrant syncs.
# If it DEFERS (returns non-zero: another migrate in progress / unresolved), skip the
# three Qdrant syncs this pull so an ingest can't pre-empt a pending adopt — they catch
# up on the next pull once migration settles. graph_sync (graphify, not Qdrant) is
# independent and always runs.
if sumela_collections_migrate; then
  sumela_memory_sync "$from" "HEAD"   # Qdrant chat_history (session summaries)
  sumela_wiki_sync   "$from" "HEAD"   # Qdrant wiki_pages   (curated wiki)
  sumela_code_sync   "$from" "HEAD"   # Qdrant code_chunks  (opt-in)
fi
sumela_graph_sync  "$from" "HEAD"   # graphify code graph
sumela_update_check                 # notice if a newer SumelaOS is available (rate-limited)
exit 0
