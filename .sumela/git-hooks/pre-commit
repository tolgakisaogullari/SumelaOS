#!/usr/bin/env bash
# pre-commit — run the SumelaOS structure validation before committing changes that
# touch the agent-control surface or the second-brain. Same check CI runs, locally.
#
# Best-effort + scoped: only validates when relevant files are staged, so unrelated
# commits are never slowed. Bypass a single commit with `git commit --no-verify`,
# or disable entirely with `export SUMELA_DISABLE_PRECOMMIT=1`.

[ -n "${SUMELA_DISABLE_PRECOMMIT:-}" ] && exit 0

# Anchor to the SumelaOS install dir — this hook lives at <install>/.sumela/git-hooks/,
# so deriving the root from $0 (not `git rev-parse --show-toplevel`) makes a monorepo
# subpackage install validate its OWN subtree instead of silently no-op'ing because
# scripts/ isn't at the repo root.
hookdir="$(cd "$(dirname "$0")" 2>/dev/null && pwd)" || exit 0
install="$(cd "$hookdir/../.." 2>/dev/null && pwd)" || exit 0
cd "$install" || exit 0
[ -f scripts/validate-structure.sh ] || exit 0   # not a SumelaOS install → do nothing

staged="$(git diff --cached --name-only --diff-filter=ACM 2>/dev/null)"
rc=0

# Secret scan — opt-in BY PRESENCE (we recommend a scanner, never reinvent one or
# force a dependency). If gitleaks is installed, scan the staged changes and BLOCK
# on a finding; if it isn't, do nothing (no per-commit nag — `status.sh` surfaces
# the one-time recommendation instead). Disable with SUMELA_DISABLE_SECRET_SCAN=1.
if [ -z "${SUMELA_DISABLE_SECRET_SCAN:-}" ] && command -v gitleaks >/dev/null 2>&1; then
  # gitleaks deprecated `protect` in v8.19 in favour of `git`; `protect` still works
  # across 8.x, so try it first and fall back to the modern form if this build has
  # dropped it. Both scan the STAGED index — the correct pre-commit scope.
  gl_out="$(gitleaks protect --staged --no-banner 2>&1)"; gl_rc=$?
  case "$gl_out" in *"unknown command"*|*"unknown flag"*)
    gl_out="$(gitleaks git --staged --no-banner 2>&1)"; gl_rc=$? ;;
  esac
  if [ "$gl_rc" -ne 0 ]; then
    case "$gl_out" in
      *"unknown command"*|*"unknown flag"*|*"unknown shorthand"*|*"Usage:"*|*"Error:"*)
        # A tool/version/config failure is NOT a secret — warn, never block (stay light).
        echo "sumela: secret scan skipped — gitleaks present but its command failed (version mismatch?):" >&2
        printf '%s\n' "$gl_out" | tr '\n' ' ' | cut -c1-200 | sed 's/^/        /' >&2 ;;
      *)
        echo "sumela: gitleaks flagged a potential secret in your staged changes." >&2
        echo "        Review:  gitleaks git --staged --verbose   (older gitleaks: gitleaks protect --staged --verbose)" >&2
        echo "        Remove the secret, or bypass this one commit with 'git commit --no-verify'." >&2
        rc=1 ;;
    esac
  fi
fi

# IDE mirror drift — checked ALWAYS (cheap; a no-op unless .sumela/mirrors.conf lists
# mirrors). Run unconditionally because mirror files (e.g. .claude/agents/*) don't
# match the agent-surface scope below, so scoping would miss a mirror-only commit.
if [ -f scripts/sync-mirrors.sh ]; then
  bash scripts/sync-mirrors.sh --check || { echo "sumela: IDE mirror(s) drifted from sumela-prompt.md — run 'bash scripts/sync-mirrors.sh'." >&2; rc=1; }
fi

# Structure validation — only when staged files touch the agent-control surface /
# second-brain / generated config (heavier check; pass instantly otherwise).
case "$staged" in
  *.sumela/*|*docs/second-brain/*|*AGENTS.md*|*RULE_REGISTRY.md*)
    echo "sumela: validating structure (pre-commit; bypass with 'git commit --no-verify')…"
    bash scripts/validate-structure.sh --check-placeholders || rc=1 ;;
esac

if [ "$rc" -ne 0 ]; then
  echo "sumela: pre-commit checks FAILED — fix the issues above, or re-run with 'git commit --no-verify' to bypass." >&2
fi
exit "$rc"
