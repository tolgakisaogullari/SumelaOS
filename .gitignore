# Generated files (created by setup.sh)
# NOTE: framework-repo only — bootstrap.sh does NOT copy this .gitignore into user
# projects, so these are tracked deliverables THERE but generated artifacts HERE.
# They keep a maintainer/CI `setup.sh` run in the framework root from polluting/leaking.
AGENTS.md
RULE_REGISTRY.md
docs/second-brain/wiki/
.claude/
.github/CODEOWNERS
.sumela/rules/domains/
.sumela/rules/backend_standards.md
.sumela/rules/frontend_standards.md
.sumela/rules/mobile_standards.md
.sumela/rules/operational_excellence_maintenance.md
# Memory-sync / graph-sync hook local logs + state (per-developer)
.sumela/.memory-sync.log
.sumela/.graph-sync.log
.sumela/.code-chunks-synced
.sumela/.update-check

# Per-developer overrides (personal; .example stays tracked)
.sumela/local.md

# Brownfield migration quarantine + AGENTS.md backup (may hold legacy secrets — never commit)
.sumela/_migration/
AGENTS.md.bak*

# Common secret files (never commit; see .sumela/rules/security_protocol.md)
.env
.env.*
!.env.example
!.env.*.example
*.pem
*.key
*.p12
*.pfx
*.secret
secrets.json
